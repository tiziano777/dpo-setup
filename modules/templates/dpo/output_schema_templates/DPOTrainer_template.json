{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DPO Dataset Sample Schema",
  "type": "object",
  "required": ["prompt", "chosen", "rejected", "_source_uri", "_replica", "_system_prompt_id"],
  "properties": {
    "prompt": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["role", "content"],
        "properties": {
          "role": { "type": "string" },
          "content": { "type": "string" }
        }
      }
    },
    "chosen": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["role", "content"],
        "properties": {
          "role": { "type": "string" },
          "content": { "type": "string" }
        }
      }
    },
    "rejected": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["role", "content"],
        "properties": {
          "role": { "type": "string" },
          "content": { "type": "string" }
        }
      }
    },
    "_source_uri": { "type": "string" },
    "_replica": { "type": "integer" },
    "_system_prompt_id": { "type": "string" },
    "_id_hash":{"type": "string","pattern": "^[a-fA-F0-9]{64}$"}
  }
}