{
  "type": "object",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "required": [
    "messages",
    "_lang",
    "_dataset_path",
    "_subpath",
    "_filename",
    "_dataset_name",
    "_id_hash"
  ],
  "properties": {
    "_lang": {
      "type": "string",
      "maxLength": 2
    },
    "_id_hash": {
      "type": "string",
      "pattern": "^[a-fA-F0-9]{64}$"
    },
    "_subpath": {
      "type": "string"
    },
    "messages": {
      "type": "array",
      "items": {
        "if": {
          "properties": {
            "role": {
              "const": "USER"
            }
          }
        },
        "else": {
          "required": [
            "positives",
            "negatives"
          ],
          "properties": {
            "role": {
              "const": "ASSISTANT"
            },
            "negatives": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/inference_item"
              }
            },
            "positives": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/inference_item"
              }
            }
          },
          "additionalProperties": true
        },
        "then": {
          "required": [
            "content"
          ],
          "properties": {
            "role": {
              "const": "USER"
            },
            "content": {
              "type": "string",
              "minLength": 1
            },
            "context": {
              "type": [
                "string",
                "null"
              ]
            }
          },
          "additionalProperties": true
        },
        "type": "object",
        "required": [
          "role"
        ],
        "properties": {
          "role": {
            "enum": [
              "USER",
              "ASSISTANT"
            ]
          }
        }
      },
      "minItems": 2
    },
    "_filename": {
      "type": "string"
    },
    "_dataset_name": {
      "type": "string"
    },
    "_dataset_path": {
      "type": "string"
    }
  },
  "definitions": {
    "inference_item": {
      "type": "object",
      "properties": {
        "score": {
          "type": "number",
          "maximum": 1,
          "minimum": 0
        },
        "think": {
          "type": [
            "string",
            "null"
          ]
        },
        "content": {
          "type": [
            "string",
            "null"
          ]
        },
        "context": {
          "type": [
            "string",
            "null"
          ]
        },
        "inference_params": {
          "type": [
            "object",
            "null"
          ],
          "properties": {
            "top_k": {
              "type": "number"
            },
            "top_p": {
              "type": "number"
            },
            "model_id": {
              "type": "string"
            },
            "temperature": {
              "type": "number"
            },
            "system_prompt_id": {
              "type": [
                "string",
                "null"
              ]
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}